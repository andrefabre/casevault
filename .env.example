# Environment variables declared in this file are available at build-time
# To declare variables at runtime, create a new file called .env.local

# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Application
APP_NAME="MyDigitalLegacy Vault"
APP_VERSION="1.0.0"

# Security
ENCRYPTION_KEY="your-encryption-key-here-32-chars"
JWT_SECRET="your-jwt-secret-here"

# File Upload
MAX_FILE_SIZE=5242880 # 5MB in bytes
UPLOAD_DIR="./uploads"